root = true

[*]
charset = utf-8
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
indent_style = space
indent_size = 2

[*.md]
# Prettier wraps prose at ~80 cols; don't auto-trim trailing whitespace in
# markdown since two trailing spaces are a hard line break.
trim_trailing_whitespace = false

[*.sh]
indent_size = 2

[Makefile]
indent_style = tab
